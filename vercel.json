{
    "buildCommand": "npm run build:client",
    "outputDirectory": "dist/public",
    "installCommand": "npm install",
    "framework": "vite",
    "rewrites": [
        {
            "source": "/assets/(.*)",
            "destination": "/assets/$1"
        },
        {
            "source": "/gallery/(.*)",
            "destination": "/gallery/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
